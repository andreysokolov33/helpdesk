# Скопируйте в .env и подставьте значения перед: docker compose up --build

MODE=PROD
APP_PORT=8000
# Имя и тег образа для docker compose (docker images / docker ps)
HELPDESK_IMAGE=helpdesk:1.0.0
BASE_SITE_URL=http://localhost:8000

SECRET_KEY=change-me-access-secret-min-32-chars
REFRESH_SECRET_KEY=change-me-refresh-secret-min-32-chars
ALGORITHM=HS256

DB_HOST=10.0.0.1
DB_USER=helpdesk
DB_PASS=helpdesk
DB_NAME=helpdesk
DB_PORT=5432

REDIS_HOST=10.0.0.2
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=

# Из контейнера 127.0.0.1 — это сам контейнер, не хост. Указывайте IP сервера БД/Redis
# или host.docker.internal (Linux: extra_hosts в compose при необходимости).

WEB_CONCURRENCY=2
TIMEOUT=120

SMTP_HOST_SKYSTREAM=smtp.yandex.com
SMTP_PORT_SKYSTREAM=465
SMTP_USE_SSL_SKYSTREAM=true
SMTP_STARTTLS_SKYSTREAM=false
SMTP_USER_SKYSTREAM=
SMTP_PASSWORD_SKYSTREAM=
SMTP_FROM_EMAIL_SKYSTREAM=
SMTP_FROM_NAME_SKYSTREAM=WiFiТочка
